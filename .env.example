# Copy to .env and keep it local. The repository .gitignore excludes .env files.
RETURN_AUTOMATION_HOST=127.0.0.1
RETURN_AUTOMATION_PORT=3206
RETURN_AUTOMATION_CDP_PORT=9333
BROWSER_HEADLESS=true
BROWSER_BRING_TO_FRONT=false
BROWSER_USER_DATA_DIR=.runtime/edge-user-data
BROWSER_EDGE_PATH=C:\Program Files (x86)\Microsoft\Edge\Application\msedge.exe
DRY_RUN_DEFAULT=true
REAL_CREATE_MAX_PER_JOB=1
ORDER_CONCURRENCY=5
PREFER_CRAWLER_ONLY=false
API_MODE=api

# Shared MySQL used by the TEMU dashboard. RETURN_DB_* takes priority,
# DB_* / MYSQL_* are also supported for compatibility.
RETURN_DB_HOST=127.0.0.1
RETURN_DB_PORT=3306
RETURN_DB_USER=temu_app
RETURN_DB_PASSWORD=
RETURN_DB_NAME=temu_monitor
DASHBOARD_BASE_URL=http://127.0.0.1:3106

# Optional: used by tests when the server runs elsewhere.
RETURN_AUTOMATION_TEST_URL=http://127.0.0.1:3206

WINIT_USERNAME=
WINIT_PASSWORD=
GOODCANG_USERNAME=
GOODCANG_PASSWORD=
ECCANG_USERNAME=
ECCANG_PASSWORD=

GOODCANG_API_BASE=https://oms.goodcang.net/public_open
GOODCANG_APP_TOKEN=
GOODCANG_APP_KEY=

WINIT_API_BASE=https://openapi.winit.com.cn/openapi/service
WINIT_TOKEN=
WINIT_APP_KEY=
WINIT_PLATFORM=OWNERERP
WINIT_CLIENT_ID=
WINIT_CLIENT_SECRET=

ECCANG_API_BASE=http://openapi-web.eccang.com/openApi/api/unity
ECCANG_APP_KEY=
ECCANG_APP_SECRET=
ECCANG_SERVICE_ID=
ECCANG_CHARSET=UTF-8
ECCANG_SIGN_UPPERCASE=true
